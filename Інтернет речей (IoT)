      borderColor: '#42a5f5',
      backgroundColor:'rgba(66,165,245,0.3)',
      tension:0.4,
      fill:true,
      pointBackgroundColor:'#ffeb3b',
      pointRadius:6
    }]
  },
  options:{
    responsive:true,
    plugins:{
